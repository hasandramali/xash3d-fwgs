<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="@string/storage_settings">
        <Preference
            app:key="game_path"
            app:title="@string/game_data_location"
            app:summary="Storage path will be updated automatically" />
            
        <SwitchPreferenceCompat
            app:key="storage_toggle"
            app:title="@string/toggle_storage_location"
            app:summaryOn="@string/using_internal_storage"
            app:summaryOff="@string/using_external_storage"
            app:defaultValue="false" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/global_settings">
        <Preference
            app:key="global_arguments"
            app:title="@string/global_command_line"
            app:summary="set any arguments" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/resolution_settings">
        <SwitchPreferenceCompat
            app:key="resolution_enabled"
            app:title="@string/resolution_fixed_title"
            app:summary="@string/resolution_fixed_summary"
            app:defaultValue="false" />

        <Preference
            app:key="resolution_settings"
            app:title="@string/resolution_custom_title"
            app:summary="Tap to configure resolution"
            app:dependency="resolution_enabled" />

        <Preference
            app:key="resolution_current"
            app:title="Current Resolution"
            app:summary="Not set"
            app:enabled="false" />
    </PreferenceCategory>

</PreferenceScreen>
